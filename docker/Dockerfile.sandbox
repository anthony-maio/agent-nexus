FROM python:3.12-slim

WORKDIR /app

# Docker CLI is required for SANDBOX_EXECUTION_BACKEND=docker.
# Keep container user as root so it can access Docker daemon endpoints.
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    docker.io \
    gcc \
    libpq-dev \
    && rm -rf /var/lib/apt/lists/*

COPY pyproject.toml .
COPY src/ src/

RUN pip install --no-cache-dir .

RUN mkdir -p /app/data /app/config

ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH=/app/src

EXPOSE 8020

CMD ["python", "-m", "nexus_sandbox_runner"]
