# === APP-FIRST REQUIRED ===
# Primary control plane DB (Postgres recommended for production)
APP_DATABASE_URL=postgresql+psycopg://nexus:nexus@nexus-postgres:5432/nexus
APP_ADMIN_USERNAME=admin
APP_ADMIN_PASSWORD=change-me-now

# App API + sandbox service wiring
APP_HOST=0.0.0.0
APP_PORT=8000
SANDBOX_RUNNER_URL=http://nexus-sandbox-runner:8020
SANDBOX_RUNNER_TOKEN=
APP_CANONICAL_WORKSPACE=workspace/app

# Sandbox execution backend
# local  -> in-process per-step ephemeral workspace
# docker -> one throwaway container per step
# Note: docker backend requires Docker CLI availability from the sandbox-runner process.
SANDBOX_EXECUTION_BACKEND=local
SANDBOX_DOCKER_IMAGE=python:3.13-slim@sha256:8bc60ca09afaa8ea0d6d1220bde073bacfedd66a4bf8129cbdc8ef0e16c8a952
# Comma-separated exact image refs allowed for docker backend.
SANDBOX_DOCKER_ALLOWED_IMAGES=python:3.13-slim@sha256:8bc60ca09afaa8ea0d6d1220bde073bacfedd66a4bf8129cbdc8ef0e16c8a952
SANDBOX_DOCKER_BIN=docker
# If using docker-compose profile sandbox-docker, the default dind endpoint is:
# SANDBOX_DOCKER_HOST=tcp://nexus-sandbox-dind:2376
SANDBOX_DOCKER_HOST=tcp://nexus-sandbox-dind:2376
SANDBOX_DOCKER_TLS_VERIFY=1
SANDBOX_DOCKER_CERT_PATH=/certs/client
SANDBOX_DOCKER_NETWORK=none
SANDBOX_DOCKER_MEMORY=512m
SANDBOX_DOCKER_CPUS=1.0
SANDBOX_DOCKER_PIDS=128
SANDBOX_STEP_TIMEOUT_SEC=120

# === MODEL BACKEND (RECOMMENDED) ===
OPENROUTER_API_KEY=

# === OPTIONAL DISCORD (bridge or legacy bot) ===
DISCORD_TOKEN=
# DISCORD_GUILD_ID=
DISCORD_BRIDGE_CHANNEL=human
# APP_API_URL=http://nexus-api:8000
# APP_API_TOKEN=

# === MODELS (set by setup wizard) ===
# Comma-separated OpenRouter model IDs for the main swarm
# SWARM_MODELS=minimax/minimax-m2.5,z-ai/glm-5,moonshotai/kimi-k2.5,qwen/qwen3-coder-next

# Embedding model (CANNOT be changed after first run)
# EMBEDDING_MODEL=qwen/qwen3-embedding-8b

# === OPTIONAL: Premium model API keys ===
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=

# === OPTIONAL: Local models ===
# OLLAMA_BASE_URL=http://host.docker.internal:11434

# === OPTIONAL: PiecesOS ===
# PIECES_MCP_ENABLED=false
# PIECES_MCP_URL=http://host.docker.internal:39300

# === INFRASTRUCTURE (defaults work with docker-compose) ===
# QDRANT_URL=http://nexus-qdrant:6333
# REDIS_URL=redis://nexus-redis:6379/0

# === CONTINUITY CORE (C2) BACKENDS ===
# Override these when running services externally (not via Docker profiles).
# C2_NEO4J_URI=bolt://nexus-neo4j:7687
# C2_NEO4J_USER=neo4j
# C2_NEO4J_PASSWORD=nexus-c2-graph
# C2_POSTGRES_URL=postgresql://nexus:nexus@nexus-postgres:5432/nexus
# C2_QDRANT_URL=http://nexus-qdrant:6333
# C2_REDIS_URL=redis://nexus-redis:6379/0
# C2_EMBEDDING_BACKEND=openrouter
# C2_OPENROUTER_EMBED_MODEL=qwen/qwen3-embedding-8b

# === ORCHESTRATOR ===
# ORCHESTRATOR_INTERVAL=3600
# AUTONOMY_MODE=escalate
# ACTIVITY_POLL_INTERVAL=60
# CROSSTALK_PROBABILITY=0.3
# CONSENSUS_THRESHOLD=0.5
